---
import Base from '../layouts/Base.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="profile-layout">
    <aside class="profile-sidebar">
      <img class="profile-photo" src="/headshot.jpeg" alt="Portrait of Juthika Saxena" />
      <h1>Juthika Saxena</h1>
      <p class="profile-role">Senior Associate at PwC</p>

      <ul class="profile-facts">
        <li>Bengaluru, India</li>
        <li>Finance transformation</li>
        <li>Treasury, GBS, analytics, AI enablement</li>
      </ul>

      <div class="profile-links">
        <a href="https://linkedin.com/in/dasjuthika" target="_blank" rel="noreferrer">LinkedIn</a>
        <a href="mailto:juthikasaxena@gmail.com">Email</a>
        <a href="https://everything3dindia.com" target="_blank" rel="noreferrer">Everything 3D</a>
        <a href="/writings">Writings</a>
      </div>
    </aside>

    <div class="profile-main">
      <section>
        <h2>About</h2>
        <p>
          I work in finance transformation at PwC, helping organizations improve
          treasury, reporting, working capital, and shared services operations.
          My work usually sits between business teams, finance teams, and systems
          teams, with a focus on making processes clearer, more scalable, and more
          useful for decision-making.
        </p>
        <p>
          Before consulting, I worked in operations and business roles at Stanza
          Living and Ola. I am also building
          <a href="https://everything3dindia.com" target="_blank" rel="noreferrer">Everything 3D</a>,
          a custom 3D printing venture. Across all of these, the thread that keeps
          pulling me back is the same: solving practical problems with structure,
          judgment, and follow-through.
        </p>
      </section>

      <section>
        <h2>Selected experience</h2>

        <article class="experience-item">
          <h3>PwC</h3>
          <p class="experience-meta">Senior Associate | Jun 2022 - Present</p>
          <p>
            Working across finance transformation, treasury, working capital, and
            platform development engagements.
          </p>
          <ul>
            <li>Led and supported 20+ projects across R2R, P2P, O2C, and working capital.</li>
            <li>Deployed Kyriba treasury capabilities across 10+ banking integrations for a client managing about $2bn in annual payment flows.</li>
            <li>Built Power BI dashboards and cost models to support decision-making and new transformation programs.</li>
            <li>Developed an AI-enabled BI chatbot in Python connected to dashboard data.</li>
          </ul>
        </article>

        <article class="experience-item">
          <h3>Stanza Living</h3>
          <p class="experience-meta">Operations Manager | Jan 2018 - Nov 2018</p>
          <p>
            Managed vendor operations, collections, and process improvement in a
            fast-growing operating environment.
          </p>
        </article>

        <article class="experience-item">
          <h3>Ola</h3>
          <p class="experience-meta">Business Analyst | Jul 2016 - Jul 2017</p>
          <p>
            Worked on category launch and commercial analysis, including the Kolkata
            launch of rental and outstation services.
          </p>
        </article>

        <article class="experience-item">
          <h3>NatWest Group</h3>
          <p class="experience-meta">Strategy Consultant Intern | Apr 2021 - Jun 2021</p>
          <p>
            Worked on customer operations analytics and NLP-led automation to improve
            service quality and reduce manual effort.
          </p>
        </article>
      </section>

      <section>
        <h2>What I work on</h2>
        <ul class="plain-list">
          <li>Finance transformation and future-state design</li>
          <li>Treasury and working capital improvement</li>
          <li>Shared services and operating model thinking</li>
          <li>Analytics, dashboards, and practical AI applications</li>
          <li>Cross-functional implementation and stakeholder alignment</li>
        </ul>
      </section>

      <section>
        <h2>Education</h2>
        <p>IIM Lucknow, MBA in Finance, 2020 - 2022</p>
        <p>IIT Guwahati, B.Tech in Civil Engineering, 2012 - 2016</p>
      </section>

      <section>
        <h2>Beyond work</h2>
        <p>
          I care about entrepreneurship, disciplined execution, and building things
          that are useful in the real world. I have also been deeply involved in
          sport, leadership, and community work, all of which have shaped how I
          think about consistency and responsibility.
        </p>
      </section>
    </div>
  </section>
</Base>
