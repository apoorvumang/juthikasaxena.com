---
import Base from '../layouts/Base.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="hero-panel">
    <div class="hero-copy">
      <p class="eyebrow">Finance Transformation | Operating Model | AI Enablement</p>
      <h1>Juthika Saxena</h1>
      <p class="lead hero-lead">
        Finance transformation consultant helping organizations modernize
        treasury, reporting, shared services, and working capital operations
        through sharper process design, analytics, and technology-led execution.
      </p>
      <p class="hero-summary">
        Currently a Senior Associate at
        <a href="https://linkedin.com/in/dasjuthika" target="_blank" rel="noreferrer">PwC</a>,
        with experience across enterprise finance, category strategy, operations,
        and venture building. My work spans client problem-solving from diagnosis
        to delivery, with a focus on turning fragmented finance environments into
        scalable, insight-led operating models.
      </p>
      <div class="hero-actions">
        <a class="button-primary" href="https://linkedin.com/in/dasjuthika" target="_blank" rel="noreferrer">
          View LinkedIn
        </a>
        <a class="button-secondary" href="/writings">
          Read Writings
        </a>
      </div>
    </div>

    <aside class="hero-aside">
      <img class="bio-photo bio-photo-square" src="/headshot.jpeg" alt="Portrait of Juthika Saxena" />
      <div class="profile-note">
        <p class="profile-label">Based in</p>
        <p>Bengaluru, India</p>
      </div>
      <div class="profile-note">
        <p class="profile-label">Core sectors</p>
        <p>Finance transformation, treasury, GBS, cost modelling, analytics</p>
      </div>
      <div class="profile-note">
        <p class="profile-label">Education</p>
        <p>IIM Lucknow MBA | IIT Guwahati B.Tech</p>
      </div>
    </aside>
  </section>

  <section class="metrics-row" aria-label="Selected impact metrics">
    <article class="metric-card">
      <p class="metric-value">20+</p>
      <p class="metric-label">finance transformation projects delivered across R2R, P2P, O2C and working capital</p>
    </article>
    <article class="metric-card">
      <p class="metric-value">$1M+</p>
      <p class="metric-label">technology cost and transformation deal value enabled through client baseline modelling</p>
    </article>
    <article class="metric-card">
      <p class="metric-value">10+</p>
      <p class="metric-label">banking integrations deployed for treasury transformation programs</p>
    </article>
    <article class="metric-card">
      <p class="metric-value">100+</p>
      <p class="metric-label">professionals trained through internal capability-building and project readiness sessions</p>
    </article>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">What I Work On</p>
      <h2>Consulting at the intersection of finance, systems, and execution</h2>
    </div>
    <div class="service-grid">
      <article>
        <h3>Finance transformation</h3>
        <p>
          Future-state design, process assessments, shared services modelling,
          governance, and cross-functional transformation planning.
        </p>
      </article>
      <article>
        <h3>Treasury and cash visibility</h3>
        <p>
          Treasury stack deployment, payment process design, connectivity
          integration, and working capital reporting for decision-ready finance teams.
        </p>
      </article>
      <article>
        <h3>Analytics and AI enablement</h3>
        <p>
          Power BI dashboards, cost models, operational analytics, and practical
          AI tooling that improves insight generation without disrupting delivery.
        </p>
      </article>
      <article>
        <h3>Operating rigor</h3>
        <p>
          Stakeholder alignment, training, implementation support, and execution
          discipline shaped by roles in high-growth operations and venture building.
        </p>
      </article>
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Experience</p>
      <h2>Professional journey</h2>
    </div>

    <div class="timeline">
      <article class="timeline-item">
        <div class="timeline-meta">
          <p class="timeline-company">PwC</p>
          <p class="timeline-role">Senior Associate</p>
          <p class="timeline-period">Jun 2022 - Present</p>
        </div>
        <div class="timeline-content">
          <p>
            Delivering finance transformation and platform development work across
            treasury, working capital, GBS, TCO modelling, and enterprise process redesign.
          </p>
          <ul class="timeline-points">
            <li>Deployed Kyriba treasury capabilities across 10+ banking integrations supporting roughly $2bn in annual payment flows.</li>
            <li>Led global delivery of working capital dashboards in Power BI, helping secure a $250K pilot engagement.</li>
            <li>Built standardized GBS and TCO cost models to accelerate client prototyping and decision-making.</li>
            <li>Developed an AI-powered BI chatbot in Python connected to dashboard data with reported 99% query accuracy.</li>
            <li>Led 20+ projects across R2R, P2P, O2C and working capital, including assessments, gap analyses and future-state design.</li>
          </ul>
        </div>
      </article>

      <article class="timeline-item">
        <div class="timeline-meta">
          <p class="timeline-company">Stanza Living</p>
          <p class="timeline-role">Operations Manager</p>
          <p class="timeline-period">Jan 2018 - Nov 2018</p>
        </div>
        <div class="timeline-content">
          <p>
            Managed vendor operations, working capital routines, and cross-functional execution
            in a fast-scaling consumer operations environment.
          </p>
          <ul class="timeline-points">
            <li>Negotiated vendor contracts and rolled out services across 15 North Delhi properties.</li>
            <li>Reduced complaint management turnaround time by 66% through CRM process redesign.</li>
            <li>Saved 80+ hours of manual effort by automating rent collection and attendance dashboards.</li>
            <li>Led end-to-end operations for a 250-bed South Delhi portfolio representing 13% of the business.</li>
          </ul>
        </div>
      </article>

      <article class="timeline-item">
        <div class="timeline-meta">
          <p class="timeline-company">Ola Cabs</p>
          <p class="timeline-role">Business Analyst</p>
          <p class="timeline-period">Jul 2016 - Jul 2017</p>
        </div>
        <div class="timeline-content">
          <p>
            Worked on launch strategy, category growth, and data-backed commercial interventions
            in one of India&apos;s highest-velocity mobility businesses.
          </p>
          <ul class="timeline-points">
            <li>Led the Kolkata launch of rental and outstation categories with cross-functional delivery teams.</li>
            <li>Improved product acceptance fivefold in two months through targeted partner and driver training.</li>
            <li>Designed a three-factor incentive structure that increased supply by 16% while reducing incentive per booking by 36%.</li>
            <li>Drove 30+ segmented campaigns that increased quarterly app sessions by 17%.</li>
          </ul>
        </div>
      </article>

      <article class="timeline-item">
        <div class="timeline-meta">
          <p class="timeline-company">NatWest Group</p>
          <p class="timeline-role">Strategy Consultant Intern</p>
          <p class="timeline-period">Apr 2021 - Jun 2021</p>
        </div>
        <div class="timeline-content">
          <p>
            Focused on customer operations analytics and capability enhancement through NLP-led automation.
          </p>
          <ul class="timeline-points">
            <li>Built an NLP-based query categorization pipeline that saved 90 manual hours per month.</li>
            <li>Recommended chat transfer interventions from analysis of 700K+ queries, contributing to a 17% NPS uplift opportunity.</li>
            <li>Helped improve CSAT by 23% through revised scripts and service model adjustments.</li>
          </ul>
        </div>
      </article>
    </div>
  </section>

  <section class="section-block section-split">
    <div>
      <div class="section-heading">
        <p class="eyebrow">Entrepreneurial Work</p>
        <h2>Operating beyond consulting</h2>
      </div>
      <div class="venture-grid">
        <article>
          <h3>Everything 3D</h3>
          <p class="venture-meta">Co-founder | 2024 - Present</p>
          <p>
            Built a custom 3D-printing business serving personal and corporate gifting
            use cases, with delivery across 500+ orders and go-to-market execution
            spanning Shopify, Instagram, Meta Ads, and direct outreach.
          </p>
        </article>
        <article>
          <h3>Empire Raas</h3>
          <p class="venture-meta">Founder | 2018 - 2019</p>
          <p>
            Built an ecommerce platform for Assamese weavers, partnered with NGOs,
            and designed a model that shared profits with artisans while growing
            reach through local brand-building and digital campaigns.
          </p>
        </article>
      </div>
    </div>

    <aside class="credentials-panel">
      <div>
        <p class="eyebrow">Education</p>
        <h3>IIM Lucknow</h3>
        <p>MBA, Finance</p>
        <p class="credential-year">2020 - 2022</p>
      </div>
      <div>
        <h3>IIT Guwahati</h3>
        <p>B.Tech, Civil Engineering</p>
        <p class="credential-year">2012 - 2016</p>
      </div>
      <div>
        <p class="eyebrow">Leadership</p>
        <p>Hiring lead at PwC and Stanza Living, with additional leadership across entrepreneurship and student communities.</p>
      </div>
      <div>
        <p class="eyebrow">Beyond work</p>
        <p>Table tennis gold medalist, community engagement volunteer, and disciplined operator shaped by sport and execution.</p>
      </div>
    </aside>
  </section>

  <section class="contact-band">
    <div>
      <p class="eyebrow">Connect</p>
      <h2>Open to meaningful conversations around finance transformation and operating model change.</h2>
    </div>
    <div class="contact-links">
      <a href="mailto:juthikasaxena@gmail.com">juthikasaxena@gmail.com</a>
      <a href="https://linkedin.com/in/dasjuthika" target="_blank" rel="noreferrer">LinkedIn</a>
      <a href="https://everything3dindia.com" target="_blank" rel="noreferrer">Everything 3D</a>
      <a href="https://instagram.com/juthika.saxena" target="_blank" rel="noreferrer">Instagram</a>
    </div>
  </section>
</Base>
