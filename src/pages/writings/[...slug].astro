---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writings', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'writings'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={post.data.title} description={post.data.description ?? post.data.title}>
  <article>
    <p class="post-meta">
      {post.data.category && <span>{post.data.category} &middot; </span>}
      <time datetime={post.data.pubDate.toISOString()}>
        {dateFmt.format(post.data.pubDate)}
      </time>
      {post.data.updatedDate && (
        <span> &middot; updated {dateFmt.format(post.data.updatedDate)}</span>
      )}
    </p>
    <h1>{post.data.title}</h1>
    {post.data.description && <p class="lead">{post.data.description}</p>}

    <div class="post-content">
      <Content />
    </div>
  </article>

  <p style="margin-top: 3rem;">
    <a href="/writings">&larr; Back to writings</a>
  </p>
</Base>
