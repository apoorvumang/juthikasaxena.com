---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('writings', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base
  title="Writings"
  description="Notes from Juthika Saxena on finance transformation, AI, consulting, entrepreneurship, motherhood, fitness, and personal growth."
>
  <p class="eyebrow">Writings</p>
  <h1>Notes on work, growth, and building a disciplined life.</h1>
  <p class="lead">
    I write about finance transformation, AI in everyday work, consulting,
    entrepreneurship, motherhood, fitness, and the lessons I'm learning while
    trying to build a thoughtful, disciplined life.
  </p>

  <h2>Categories</h2>
  <ul class="tag-list">
    <li>Finance Transformation</li>
    <li>AI Experiments</li>
    <li>Consulting Notes</li>
    <li>Entrepreneurship</li>
    <li>Motherhood</li>
    <li>Fitness &amp; Discipline</li>
    <li>Personal Reflections</li>
  </ul>

  <h2>Posts</h2>

  {posts.length === 0 ? (
    <div class="empty-state">
      <p>New writing coming soon.</p>
    </div>
  ) : (
    <div class="writings-list">
      {posts.map((post) => (
        <article class="writing-item">
          <p class="writing-meta">
            {post.data.category && <span>{post.data.category}</span>}
            <span>{dateFmt.format(post.data.pubDate)}</span>
          </p>
          <h3>
            <a href={`/writings/${post.slug}/`}>{post.data.title}</a>
          </h3>
          {post.data.description && (
            <p class="writing-summary">{post.data.description}</p>
          )}
        </article>
      ))}
    </div>
  )}
</Base>
